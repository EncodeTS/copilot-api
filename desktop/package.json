{
  "name": "copilot-api-desktop",
  "version": "2.0.0-rc.13",
  "packageManager": "bun@1.3.14",
  "description": "Copilot API Desktop App",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:server": "bun run --cwd .. build:desktop && node ../scripts/prepare-desktop-server-node-modules.mjs",
    "test": "bun test tests",
    "preview": "electron-vite preview",
    "gen-icons": "rsvg-convert -w 1024 -h 1024 assets/tray-icon-colored.svg -o assets/icon.png",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "package": "bun run build:server && electron-vite build && electron-builder",
    "package:mac": "bun run build:server && electron-vite build && electron-builder --mac",
    "package:win": "bun run build:server && electron-vite build && electron-builder --win",
    "package:linux": "bun run build:server && electron-vite build && electron-builder --linux",
    "smoke:server-sharp": "node ../scripts/smoke-packaged-sharp.mjs",
    "smoke:server-zstd": "node ../scripts/run-electron-zstd-smoke.mjs",
    "test:coverage": "bun test tests --coverage --coverage-reporter=lcov --coverage-dir=../coverage/desktop",
    "typecheck": "bun run typecheck:main && bun run typecheck:preload && bun run typecheck:web",
    "typecheck:main": "tsc --project tsconfig.node.json --noEmit --composite false --pretty false",
    "typecheck:preload": "tsc --project tsconfig.preload.json --noEmit --composite false --pretty false",
    "typecheck:web": "tsc --project tsconfig.web.json --noEmit --composite false --pretty false"
  },
  "dependencies": {
    "electron-updater": "^6.3.4"
  },
  "overrides": {
    "js-yaml": "4.3.0"
  },
  "build": {
    "appId": "com.copilot-api.desktop",
    "productName": "Copilot API",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "server",
        "filter": [
          "**/*.js"
        ]
      },
      {
        "from": "../pages",
        "to": "pages"
      },
      {
        "from": "build/server-package.json",
        "to": "server/package.json"
      },
      {
        "from": "build/server-node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "assets/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "assets/tray-icon@2x.png",
        "to": "tray-icon@2x.png"
      },
      {
        "from": "assets/tray-iconTemplate.png",
        "to": "tray-iconTemplate.png"
      },
      {
        "from": "assets/tray-iconTemplate@2x.png",
        "to": "tray-iconTemplate@2x.png"
      },
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.png"
    },
    "dmg": {
      "format": "ULFO"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^9.37.0",
    "@tailwindcss/vite": "^4.1.4",
    "@types/bun": "^1.2.23",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.8.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.1.0",
    "eslint": "^9.37.0",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.2.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.41.0",
    "vite": "^6.3.3"
  }
}
